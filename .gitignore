# ─── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]

# ─── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ─── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Raw data ─────────────────────────────────────────────────────────────────
# NSRDB parquet must be fetched via src/fetch_nsrdb.py (NREL API key required).
# Site metadata JSON is kept as a reference for the lat/lon and cloud-type codes.
data/raw/*.parquet

# ─── Processed data ───────────────────────────────────────────────────────────
# Horizon feature matrices are regenerated by: python src/features.py --horizon {h}
data/processed/

# ─── Trained model binaries ───────────────────────────────────────────────────
# Regenerated by: python src/stage1_finalize.py --horizon {h}
#                 python src/stage2_regressor.py --horizon {h}
*.pkl
*.joblib

# ─── Prediction output parquets ───────────────────────────────────────────────
# Regenerated by: python src/stage3b_stratified_conformal.py --horizon {h}
# Text reports (.txt), summary CSVs (.csv), and Markdown summaries (.md) are kept.
outputs/*.parquet
outputs/**/*.parquet

# ─── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# ─── Logs and temp ────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
